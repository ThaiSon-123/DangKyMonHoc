# Production environment variables
# Copy file này thành .env.production và điền giá trị thực tế trước khi deploy
# KHÔNG commit .env.production vào git

# --- Django ---
# Tạo bằng: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=replace-me-with-long-random-string

# Domain production, phân cách bằng dấu phẩy
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# --- Database ---
DB_NAME=dangkymonhoc
DB_USER=dkmh_user
# Đặt mật khẩu mạnh, không dùng "postgres"
DB_PASSWORD=replace-me-with-strong-password

# --- CORS ---
# Origin của frontend production
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# --- Frontend ---
# URL public của backend, được build vào bundle frontend
VITE_API_BASE_URL=https://api.example.com/api
